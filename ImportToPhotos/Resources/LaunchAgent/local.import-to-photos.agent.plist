<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>local.import-to-photos.agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Applications/ImportToPhotos.app/Contents/MacOS/ImportToPhotos</string>
    <string>--background-agent</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>Crashed</key>
    <true/>
  </dict>
  <key>StandardOutPath</key>
  <string>/tmp/local.import-to-photos.agent.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/local.import-to-photos.agent.err.log</string>
</dict>
</plist>
